# ===================================================
# ORM Dashboard — Environment Variables
# Copy file này thành .env.local và điền vào
# ===================================================

# --- SUPABASE (bắt buộc) ---
# Lấy tại: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...   # (tuỳ chọn, dùng để bypass RLS)

# --- AI (chọn 1 trong 2, hoặc để trống để dùng fallback) ---

# OpenAI (gpt-4o-mini, nhanh và rẻ)
# OPENAI_API_KEY=

# Gemini (thay thế OpenAI nếu không có key)
GEMINI_API_KEY=

# --- GOOGLE PLACES API (tuỳ chọn) ---
# Nếu không có, tick "Dùng dữ liệu mẫu" trên UI
GOOGLE_PLACES_API_KEY=AIza...
